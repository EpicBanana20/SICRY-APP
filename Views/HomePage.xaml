<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SICRY_APP.ViewModels"
             x:Class="SICRY_APP.Views.HomePage"
             Title="Inicio"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20,10,20,0">

        <CollectionView Grid.Row="0"
                        HeightRequest="110"
                        ItemsLayout="HorizontalList"
                        HorizontalScrollBarVisibility="Never"
                        Margin="0,0,0,15"
                        ItemsSource="{Binding Days}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding SelectDayCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="5">
                        <Frame HeightRequest="95" WidthRequest="65" CornerRadius="18" Padding="0" HasShadow="True" BorderColor="Transparent">
                            <Frame.Style>
                                <Style TargetType="Frame">
                                    <Setter Property="BackgroundColor" Value="#FBFBFB"/>
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#009688"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Frame.Style>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding DayName}" FontSize="12" HorizontalOptions="Center">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                                <Label Text="{Binding Day}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="#333"/>
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,0,0,15">
            <HorizontalStackLayout Spacing="10" Padding="0,5">
                <Button Text="Todas" BackgroundColor="White" TextColor="Gray" CornerRadius="20" HeightRequest="40" Padding="20,0" FontSize="12"/>
                <Button Text="Por hacer" BackgroundColor="#009688" TextColor="White" FontAttributes="Bold" CornerRadius="20" HeightRequest="40" Padding="20,0" FontSize="12"/>
                <Button Text="En progreso" BackgroundColor="White" TextColor="Gray" CornerRadius="20" HeightRequest="40" Padding="20,0" FontSize="12"/>
                <Button Text="Completadas" BackgroundColor="White" TextColor="Gray" CornerRadius="20" HeightRequest="40" Padding="20,0" FontSize="12"/>
            </HorizontalStackLayout>
        </ScrollView>

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding CargarAsignacionesCommand}">

            <CollectionView ItemsSource="{Binding Tareas}" VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#F2F9FA" CornerRadius="20" HasShadow="False" BorderColor="Transparent" Padding="15" Margin="0,0,0,15">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=AbrirReporteCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*, Auto">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                        <Label Text="📍" FontSize="12" VerticalOptions="Center"/>
                                        <Label Text="{Binding Pozo}" FontAttributes="Bold" FontSize="15" TextColor="#3E2723" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Frame Grid.Column="1" BackgroundColor="{Binding ColorEstadoFondo}" CornerRadius="8" Padding="10,4" HasShadow="False" BorderColor="Transparent">
                                        <Label Text="{Binding Estado}" TextColor="{Binding ColorEstado}" FontSize="11" FontAttributes="Bold"/>
                                    </Frame>
                                </Grid>

                                <Label Text="{Binding InstruccionInicial}" TextColor="#3E2723" FontSize="13" MaxLines="3" LineBreakMode="TailTruncation"/>

                                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,3"/>

                                <Grid ColumnDefinitions="*, *">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Asignado por" FontSize="10" TextColor="#B07C88"/>
                                        <Label Text="{Binding AsignadoPor}" FontSize="12" TextColor="#7D5A64" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                                        <Label Text="Fecha" FontSize="10" TextColor="#B07C88" HorizontalOptions="End"/>
                                        <Label Text="{Binding FechaFormateada}" FontSize="12" TextColor="#7D5A64" FontAttributes="Bold" HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <Label Text="Tap para crear reporte ›" FontSize="10" TextColor="#009688" HorizontalOptions="End" Margin="0,5,0,0"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="50">
                        <Label Text="📋" FontSize="60" HorizontalOptions="Center"/>
                        <Label Text="No tienes asignaciones" FontAttributes="Bold" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>
                        <Label Text="Desliza hacia abajo para actualizar" FontSize="12" TextColor="LightGray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
