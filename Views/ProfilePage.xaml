<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SICRY_APP.Views.ProfilePage"
             Title=""
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="280, *, Auto">

        <!-- ── Hero Header ── -->
        <Grid Grid.Row="0">

            <!-- Fondo de color sólido con corte diagonal simulado -->
            <BoxView BackgroundColor="{Binding ColorGafete}" VerticalOptions="Fill"/>

            <!-- Capa semitransparente superior para profundidad -->
            <BoxView BackgroundColor="#18000000" VerticalOptions="Fill"/>

            <!-- Contenido del header -->
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="14" Padding="20,50,20,30">

                <!-- Avatar circle -->
                <Grid HorizontalOptions="Center">
                    <Ellipse WidthRequest="100" HeightRequest="100"
                             Fill="White" Opacity="0.15"
                             HorizontalOptions="Center"/>
                    <Frame WidthRequest="88" HeightRequest="88" CornerRadius="44"
                           BackgroundColor="White" HasShadow="False" Padding="0"
                           HorizontalOptions="Center" BorderColor="Transparent">
                        <Label Text="{Binding Inicial}"
                               TextColor="{Binding ColorGafete}"
                               FontSize="42" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                </Grid>

                <!-- Nombre -->
                <Label Text="{Binding NombreUsuario}"
                       TextColor="White" FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>

                <!-- Badge de rol -->
                <Border StrokeThickness="0" HorizontalOptions="Center">
                    <Border.Background>
                        <SolidColorBrush Color="#33FFFFFF"/>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding RolUsuario}"
                           TextColor="White" FontSize="13" FontAttributes="Bold"
                           CharacterSpacing="1.2"
                           Margin="18,7"/>
                </Border>

            </VerticalStackLayout>
        </Grid>

        <!-- ── Cuerpo ── -->
        <ScrollView Grid.Row="1" Padding="20,24,20,0">
            <VerticalStackLayout Spacing="16">

                <!-- Tarjeta de información -->
                <Border StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,16" Spacing="0">

                        <Label Text="INFORMACIÓN DE CUENTA"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#9E9E9E" CharacterSpacing="1.5"
                               Margin="0,0,0,16"/>

                        <!-- Fila: Nombre -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="14"
                              Padding="0,10,0,10">
                            <Frame Grid.Column="0"
                                   WidthRequest="36" HeightRequest="36"
                                   CornerRadius="10" Padding="0"
                                   BackgroundColor="{Binding ColorGafete}"
                                   Opacity="0.15" HasShadow="False"
                                   BorderColor="Transparent"/>
                            <Label Grid.Column="0"
                                   Text="👤" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Nombre" FontSize="11" TextColor="#9E9E9E"/>
                                <Label Text="{Binding NombreUsuario}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#212121"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,2"/>

                        <!-- Fila: Rol -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="14"
                              Padding="0,10,0,10">
                            <Frame Grid.Column="0"
                                   WidthRequest="36" HeightRequest="36"
                                   CornerRadius="10" Padding="0"
                                   BackgroundColor="{Binding ColorGafete}"
                                   Opacity="0.15" HasShadow="False"
                                   BorderColor="Transparent"/>
                            <Label Grid.Column="0"
                                   Text="🔖" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Rol" FontSize="11" TextColor="#9E9E9E"/>
                                <Label Text="{Binding RolUsuario}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#212121"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,2"/>

                        <!-- Fila: Horas extra esta semana -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="14"
                              Padding="0,10,0,10">
                            <Frame Grid.Column="0"
                                   WidthRequest="36" HeightRequest="36"
                                   CornerRadius="10" Padding="0"
                                   BackgroundColor="{Binding ColorGafete}"
                                   Opacity="0.15" HasShadow="False"
                                   BorderColor="Transparent"/>
                            <Label Grid.Column="0"
                                   Text="⏱️" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Horas extra esta semana" FontSize="11" TextColor="#9E9E9E"/>
                                <Label Text="{Binding HorasExtrasSemana}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#212121"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,2"/>

                        <!-- Fila: Asignaciones activas -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="14"
                              Padding="0,10,0,6">
                            <Frame Grid.Column="0"
                                   WidthRequest="36" HeightRequest="36"
                                   CornerRadius="10" Padding="0"
                                   BackgroundColor="{Binding ColorGafete}"
                                   Opacity="0.15" HasShadow="False"
                                   BorderColor="Transparent"/>
                            <Label Grid.Column="0"
                                   Text="📋" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Asignaciones pendientes / en progreso" FontSize="11" TextColor="#9E9E9E"/>
                                <Label Text="{Binding AsignacionesActivas}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#212121"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{Binding ColorGafete}" Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Footer ── -->
        <VerticalStackLayout Grid.Row="2" Padding="20,16,20,36" Spacing="12">

            <Button Text="Cerrar sesión"
                    Command="{Binding CerrarSesionCommand}"
                    BackgroundColor="#FFEBEE"
                    TextColor="#D32F2F"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="14"
                    HeightRequest="52"
                    BorderColor="#FFCDD2"
                    BorderWidth="1"/>

            <Label Text="SICRY APP  •  v1.0.0"
                   TextColor="#BDBDBD" FontSize="11"
                   HorizontalOptions="Center" CharacterSpacing="0.5"/>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
