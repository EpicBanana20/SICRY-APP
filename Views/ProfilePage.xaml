<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SICRY_APP.ViewModels"
             x:Class="SICRY_APP.Views.ProfilePage"
             Title="Mi Perfil"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *, Auto">

        <Frame Grid.Row="0" 
               BackgroundColor="{Binding ColorGafete}" 
               CornerRadius="0,0,0,0" 
               Padding="20,20,20,20" 
               HasShadow="False"
               BorderColor="Transparent"
               Margin="0,10,0,0">
            <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                <Frame WidthRequest="90" HeightRequest="90" CornerRadius="45" 
                       BackgroundColor="White" HasShadow="False" Padding="0" 
                       HorizontalOptions="Center" BorderColor="Transparent">
                    <Label Text="{Binding Inicial}" TextColor="{Binding ColorGafete}" 
                           FontSize="40" FontAttributes="Bold" 
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>

                <Label Text="{Binding NombreUsuario}" 
                       TextColor="White" FontSize="24" FontAttributes="Bold" 
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <Frame BackgroundColor="#33000000" CornerRadius="15" Padding="15,5" 
                       HorizontalOptions="Center" HasShadow="False" BorderColor="Transparent">
                    <Label Text="{Binding RolUsuario}" 
                           TextColor="White" FontSize="14" FontAttributes="Bold" CharacterSpacing="1.5"/>
                </Frame>
            </VerticalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1" Padding="20,30,20,0">
            <VerticalStackLayout Spacing="20">

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                    <Frame Grid.Column="0" BackgroundColor="#FFF3E0" BorderColor="Transparent" CornerRadius="15" Padding="15" HasShadow="False">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="⚠️" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalPendientes}" FontSize="32" FontAttributes="Bold" TextColor="#E65100" HorizontalOptions="Center"/>
                            <Label Text="Por hacer" FontSize="12" TextColor="#FFB300" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" BackgroundColor="#E8F5E9" BorderColor="Transparent" CornerRadius="15" Padding="15" HasShadow="False">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="✅" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalCompletados}" FontSize="32" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                            <Label Text="Completadas" FontSize="12" TextColor="#66BB6A" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{Binding ColorGafete}" Margin="0,20,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Padding="20,10,20,30" Spacing="15">
            <Button Text="Cerrar Sesión" 
                    Command="{Binding CerrarSesionCommand}"
                    BackgroundColor="#FFEbee" 
                    TextColor="#D32F2F" 
                    FontAttributes="Bold"
                    CornerRadius="12" 
                    HeightRequest="55"
                    BorderColor="#D32F2F"
                    BorderWidth="1.5"/>

            <Label Text="SICRY APP • Versión 1.0.0" 
                   TextColor="LightGray" FontSize="11" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>